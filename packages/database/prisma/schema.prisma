// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  styleDNA     StyleDNA?
  wardrobe     WardrobeItem[]
  outfits      Outfit[]
}

model StyleDNA {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  faceShape          String?
  bodyShape          String?
  skinTone           String?
  fashionPersonality String?
  wardrobeScore      Int      @default(0)
  confidenceScore    Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WardrobeItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   String
  brand      String?
  color      String?
  imageUrl   String?
  // embeddings vector/array - depending on pgvector setup. Let's use simple string or json for now or wait for pgvector
  embeddings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outfitItems OutfitItem[]
}

model Outfit {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  occasion     String?
  aiMatchScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OutfitItem[]
}

model OutfitItem {
  id             String       @id @default(cuid())
  outfitId       String
  outfit         Outfit       @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  wardrobeItemId String
  wardrobeItem   WardrobeItem @relation(fields: [wardrobeItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
